# NYC 311 Pipeline — required environment variables
# Copy to .env and fill in values. Never commit .env.

NYC_APP_TOKEN=           # Socrata app token — https://data.cityofnewyork.us/profile/app_tokens
BRONZE_PATH=/app/data/bronze
WAREHOUSE_PATH=/app/data/nyc311.duckdb
FRED_BRONZE_PATH=/app/data/fred_bronze

# Cloudflare R2 — shared with fred pipeline
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=osp-aviation-lakehouse
