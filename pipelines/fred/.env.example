# FRED Pipeline — required environment variables
# Copy to .env and fill in values. Never commit .env.

FRED_API_KEY=            # FRED API key — https://fred.stlouisfed.org/docs/api/api_key.html
WAREHOUSE_PATH=/app/data/fred.duckdb

# Cloudflare R2 — shared with nyc311 pipeline
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=osp-aviation-lakehouse
